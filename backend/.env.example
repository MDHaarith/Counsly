# ============================================
# BACKEND — Vercel Environment Variables
# Copy these into Vercel Dashboard > Settings > Environment Variables
# ============================================

# --- Auth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SESSION_SECRET=replace-with-at-least-32-random-characters

# --- Database ---
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# --- CORS & Frontend ---
FRONTEND_URL=
CORS_ORIGINS=
TRUSTED_HOSTS=

# --- TNEA Config ---
SEASON_YEAR=2026
TNEA_PHASE=0
TOTAL_ROUNDS=0
RANK_RELEASED=false
FREE_CHAT_LIMIT=3
SEASON_END_DATE=
ROUND_1_DATE=
ROUND_2_DATE=
ROUND_3_DATE=
ROUND_4_DATE=
ROUND_5_DATE=

# --- Payments ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_AMOUNT_PAISE=14900

# --- Chat (optional) ---
OPENROUTER_API_KEY=
OPENROUTER_API_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324
